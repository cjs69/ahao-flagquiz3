    _imglevel.image = [UIImage imageNamed:[_arr_imglevels objectAtIndex:_currentLevel]];


}


-(void)initLives{
    // Set the initial value to the lives property and make all images visible.
    _lives = 3;
    _imglive1.hidden = NO;
    _imglive2.hidden = NO;
    _imglive3.hidden = NO;

}

-(void)shuffleArray{
    
    NSUInteger count = pageNames.count;
    for (NSUInteger i = 0; i < count; ++i) {
        NSInteger remainingCount = count - i;
        NSInteger exchangeIndex = i + arc4random_uniform(remainingCount);
        [_pageNames exchangeObjectAtIndex:i withObjectAtIndex:exchangeIndex];
        
    }
    
}

